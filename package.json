{
  "name": "codegen",
  "version": "0.1.0",
  "description": "AI-powered code generation CLI - supports Ollama and commercial LLMs",
  "type": "module",
  "bin": {
    "codegen": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.1.0",
    "@ai-sdk/google": "^1.1.0",
    "@ai-sdk/groq": "^1.1.0",
    "@ai-sdk/openai": "^1.1.0",
    "ai": "^4.1.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ollama": "^0.5.11",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
